# ---- Server ----
PORT=5000
# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_URL=http://localhost:5173

# ---- Database ----
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/hindu-marketplace

# ---- Auth ----
# Use a long random string (>= 32 chars), e.g. `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-secret
# Set to "true" to force email verification before login (needs EMAIL_* below)
REQUIRE_EMAIL_VERIFICATION=false

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# From the Razorpay dashboard webhook settings (Settings > Webhooks)
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# ---- Cloudinary (private PDF storage + public covers) ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxx

# ---- Reawaken course video hosting ----
# Which provider handles lesson-video uploads: cloudinary | cloudflare
# Leave unset to auto-pick (Cloudflare if configured below, else Cloudinary).
# Cloudinary uses the CLOUDINARY_* keys above; it's free-tier friendly for
# testing. Cloudflare Stream is cheaper/better for production streaming.
VIDEO_PROVIDER=cloudinary

# ---- Cloudflare Stream (only needed when VIDEO_PROVIDER=cloudflare) ----
# Account ID: Cloudflare dashboard > Stream (right sidebar)
CF_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# API token with the "Stream:Edit" permission (My Profile > API Tokens)
CF_STREAM_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Email (optional; Gmail app password) ----
EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your_gmail_app_password
